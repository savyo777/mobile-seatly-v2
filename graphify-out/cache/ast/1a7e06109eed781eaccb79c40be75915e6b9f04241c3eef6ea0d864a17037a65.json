      if (!token) return;\n\n      await supabase\n        .from('user_profiles')\n        .update({ expo_push_token: token })\n        .eq('auth_user_id', authUserId);\n    } catch {\n      // Push registration is best-effort; never let it crash the app.\n    } finally {\n      inflightRegistration = null;\n    }\n  })", "is_member_call": false, "source_file": "/Users/stevengeorgy/mobile-seatly-v2-5/lib/notifications/pushToken.ts", "source_location": "L90"}]}