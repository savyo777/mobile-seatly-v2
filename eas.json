{
  "cli": {
    "version": ">= 15.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_DEEPGRAM_STT_ENABLED": "true",
        "EXPO_PUBLIC_ELEVENLABS_ENABLED": "true"
      }
    },
    "development-simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "extends": "production",
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "distribution": "store",
      "ios": {
        "entitlements": {
          "aps-environment": "production"
        },
        "jsEngine": "hermes"
      },
      "android": {
        "buildType": "app-bundle",
        "jsEngine": "hermes"
      },
      "env": {
        "EXPO_PUBLIC_DEEPGRAM_STT_ENABLED": "true",
        "EXPO_PUBLIC_ELEVENLABS_ENABLED": "true",
        "EXPO_PUBLIC_CENAIVA_DEMO_MODE": "false",
        "EXPO_PUBLIC_CENAIVA_HOLDS_ENABLED": "true",
        "EXPO_PUBLIC_CRASH_LOGGER_ENABLED": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
