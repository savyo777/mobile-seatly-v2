{
  "expo": {
    "name": "Cenaiva",
    "slug": "cenaiva",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "cenaiva",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cenaiva.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Cenaiva uses your microphone so you can speak restaurant and booking requests.",
        "NSLocationWhenInUseUsageDescription": "Cenaiva uses your location to find nearby restaurants.",
        "NSSpeechRecognitionUsageDescription": "Cenaiva may use speech recognition to process spoken restaurant and booking requests.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "cenaiva"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "cenaiva"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "instagram",
          "snapchat",
          "tiktok",
          "youtube",
          "vnd.youtube"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.cenaiva.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "cenaiva"
            }
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Cenaiva to access your camera so you can capture and post restaurant review snaps."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Cenaiva needs access to your photo library so you can choose an image for your restaurant post."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Cenaiva uses your location to find nearby restaurants.",
          "locationAlwaysAndWhenInUsePermission": "Cenaiva uses your location to find nearby restaurants."
        }
      ],
      "expo-sharing",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Cenaiva uses your microphone so you can speak restaurant and booking requests.",
          "speechRecognitionPermission": "Cenaiva may use speech recognition to process spoken restaurant and booking requests."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Cenaiva uses your microphone so you can speak restaurant and booking requests.",
          "recordAudioAndroid": true,
          "enableBackgroundRecording": false,
          "enableBackgroundPlayback": false
        }
      ],
      "expo-asset",
      "expo-web-browser",
      "expo-image"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1e9ba9c7-4c10-442e-a345-6ca128628363"
      }
    }
  }
}
