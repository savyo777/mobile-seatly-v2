# Same Supabase project as the web app.
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_OWNER_PLAN_PRICE_ID=price_replace_me

# Owner billing display values. Surfaced in subscription-plan and
# billing-history. Server (Stripe) is the source of truth; these env
# vars exist so the UI displays consistent numbers without computing
# them on-device.
EXPO_PUBLIC_OWNER_MONTHLY_SUB_DOLLARS=
EXPO_PUBLIC_OWNER_PER_BOOKING_DOLLARS=
EXPO_PUBLIC_OWNER_PREORDER_FEE_PCT=

# How many calendar months the owner free trial lasts. Defaults to 3.
EXPO_PUBLIC_OWNER_TRIAL_MONTHS=3

# Feature flags. These are public booleans, not secrets.
EXPO_PUBLIC_DEEPGRAM_STT_ENABLED=true
EXPO_PUBLIC_ELEVENLABS_ENABLED=true
EXPO_PUBLIC_CENAIVA_DEMO_MODE=false
EXPO_PUBLIC_CENAIVA_NATIVE_STT_FIRST=
EXPO_PUBLIC_CENAIVA_VOICE_DEBUG=
# Reservation-hold system (HAB). When true, the mobile booking flow creates
# a `reservation_holds` row on step 4 and converts it on payment / place
# order — mirroring the web flow. Requires the server-side
# `CENAIVA_HOLDS_ENABLED=true` to actually convert; the mobile flag also
# gates the in-app timer UX. Set to false to revert to the legacy flow.
EXPO_PUBLIC_CENAIVA_HOLDS_ENABLED=true
# In-house crash logger. When true, JS runtime errors + render-time React
# errors get posted to the public.crash_logs table via the
# insert_crash_log RPC (see migration 20260516010000_add_crash_logs.sql).
# Read crashes via the Supabase SQL editor (service-role bypasses RLS).
# Set to false to disable entirely without a rebuild.
EXPO_PUBLIC_CRASH_LOGGER_ENABLED=true
EXPO_PUBLIC_CENAIVA_TTS_VOICE_FEMALE_ID=8vf2Pg7VZD0Piv8GA8v9
EXPO_PUBLIC_CENAIVA_TTS_VOICE_MALE_ID=f5HLTX707KIM4SzJYzSz

# Override the Deepgram STT endpoint if proxying through your own infra.
EXPO_PUBLIC_DEEPGRAM_URL=https://api.deepgram.com/v1/listen

# Turn on the Deepgram live-token edge function path. Required for the
# Hey Cenaiva voice flow on real builds — without this, fetchDeepgramToken
# short-circuits and the assistant errors with "speech service unavailable".
# The function itself is deployed at supabase/functions/deepgram-live-token.
EXPO_PUBLIC_DEEPGRAM_LIVE_TOKEN=true

# Optional Deepgram tuning. Both default to safe values; only set in .env
# if you need to override (e.g. a multi-language deployment).
EXPO_PUBLIC_DEEPGRAM_MODEL=nova-3
EXPO_PUBLIC_DEEPGRAM_LANGUAGE=en

# Brand and legal links. Override per-environment to point at the right
# legal/marketing endpoints.
EXPO_PUBLIC_BRAND_DOMAIN=cenaiva.com
EXPO_PUBLIC_TERMS_URL=https://cenaiva.com/terms
EXPO_PUBLIC_PRIVACY_URL=https://cenaiva.com/privacy
EXPO_PUBLIC_LICENSES_URL=https://cenaiva.com/licenses
EXPO_PUBLIC_ACK_URL=https://cenaiva.com/ack
EXPO_PUBLIC_SUPPORT_EMAIL=help@cenaiva.app
EXPO_PUBLIC_PRIVACY_EMAIL=privacy@cenaiva.com
EXPO_PUBLIC_LEGAL_EMAIL=legal@cenaiva.com

# Initial map center used when the user denies location permission.
# Defaults to the GTA (Cenaiva launch market).
EXPO_PUBLIC_DEFAULT_MAP_LAT=43.51025
EXPO_PUBLIC_DEFAULT_MAP_LON=-79.86635
EXPO_PUBLIC_DEFAULT_MAP_DELTA=0.022

# Public app IDs/client IDs for native social sharing. Do not put app secrets here.
EXPO_PUBLIC_INSTAGRAM_APP_ID=
EXPO_PUBLIC_TIKTOK_CLIENT_KEY=
EXPO_PUBLIC_SNAPCHAT_CLIENT_ID=


# Optional HTTPS profile links (defaults to @heycenaiva) used when opening Snapchat / TikTok from the snap reward sheet.
EXPO_PUBLIC_SNAPCHAT_PROFILE_URL=
EXPO_PUBLIC_TIKTOK_PROFILE_URL=
EXPO_PUBLIC_INSTAGRAM_PROFILE_URL=
EXPO_PUBLIC_YOUTUBE_PROFILE_URL=

# Server-side Supabase Edge Function secrets. Do not expose these to mobile clients.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
OPENAI_API_KEY=<openai-api-key>
STRIPE_SECRET_KEY=<stripe-secret-key>
CENAIVA_LATENCY_DEBUG=0
CENAIVA_OPENAI_PREWARM=0

# Hey Cenaiva rate limits — SERVER-ONLY (do NOT prefix with EXPO_PUBLIC_).
# Two protections per OpenAI-backed function, bucketed per user (with IP
# fallback). Tuning these does NOT require a code change — just redeploy
# the affected function after setting the env var.
#   Minute brake: stops accidental loops and spam.
#   Daily cap:    catches slow grinders the minute brake misses.
CENAIVA_ORCHESTRATE_MINUTE_LIMIT=6
CENAIVA_ORCHESTRATE_DAILY_LIMIT=100
CENAIVA_SMALL_PROMPT_MINUTE_LIMIT=4
CENAIVA_SMALL_PROMPT_DAILY_LIMIT=8
CENAIVA_ELEVENLABS_TTS_MINUTE_LIMIT=4
CENAIVA_ELEVENLABS_TTS_DAILY_LIMIT=12
CENAIVA_DEEPGRAM_TOKEN_MINUTE_LIMIT=6
CENAIVA_DEEPGRAM_TOKEN_DAILY_LIMIT=44

# Hard ceiling on cenaiva-orchestrate OpenAI output. Caps both raw
# OpenAI cost and downstream ElevenLabs TTS cost per request.
CENAIVA_ORCHESTRATE_MAX_OUTPUT_TOKENS=450
CENAIVA_SMALL_PROMPT_MAX_TOKENS=30
CENAIVA_TTS_TEXT_MAX_CHARS=220

# Estimated daily paid API budget guard for Hey Cenaiva. These are server-side
# estimates used by the `paid_usage_buckets` table before vendor calls.
CENAIVA_USER_DAILY_AI_BUDGET_USD=0.50
CENAIVA_COST_ORCHESTRATE_USD=0.001
CENAIVA_COST_SMALL_PROMPT_USD=0.018
CENAIVA_COST_ELEVENLABS_TTS_USD=0.025
CENAIVA_COST_DEEPGRAM_TOKEN_USD=0.003

# Comma-separated origin allowlist used by the Edge Function CORS layer
# once the wildcard is replaced. Mobile clients don't send Origin so the
# allowlist only affects browser callers.
ALLOWED_ORIGINS=

# Set to 1 in development only to allow the test-mode payment branch in
# cenaiva-orchestrate to succeed when STRIPE_SECRET_KEY is missing.
# Must remain unset in production.
CENAIVA_ALLOW_TEST_PAYMENTS=

# Currency conversion (used by the convert-currency edge function).
#
# FX_PROVIDER_URL is a templated GET endpoint with {from}, {to}, and
# optional {date} placeholders. {date} is replaced with "latest" when
# no historical date is supplied (handles providers like frankfurter
# that put the date in the URL path).
#
# Default (when unset): https://api.frankfurter.app/{date}?from={from}&to={to}
# Frankfurter is free, no key required, sources ECB daily rates.
#
# NOTE: exchangerate.host was the default until mid-2024 but now requires
# an access_key. Don't point FX_PROVIDER_URL at it unless you also set
# FX_PROVIDER_AUTH_HEADER (or append your access_key to the URL).
#
# Example values:
#   FX_PROVIDER_URL=https://api.frankfurter.app/{date}?from={from}&to={to}
#   FX_PROVIDER_URL=https://api.exchangerate.host/convert?access_key=YOURKEY&from={from}&to={to}&amount=1
#
# If the provider fails, the function falls back to an in-code rate
# table for the most common pairs (USD/CAD/EUR/GBP) so receipts still
# convert. See convert-currency/index.ts FALLBACK_RATES.
#
# FX_PROVIDER_AUTH_HEADER (optional) — header sent on the outbound rate
# request when the provider needs an API key. Format: "Header-Name: value".
FX_PROVIDER_URL=
FX_PROVIDER_AUTH_HEADER=

# Twilio — SERVER-ONLY secrets. NEVER prefix with EXPO_PUBLIC_ or
# expose to the mobile bundle. Used by edge functions
# (create-public-booking, send-waitlist-ready-sms, send-reservation-reminders)
# via the shared helper at supabase/functions/_shared/sms.ts.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=<twilio-auth-token>
TWILIO_PHONE_NUMBER=+10000000000

# Shared secret between pg_cron and the send-reservation-reminders edge
# function. Must match the value stored in Supabase Vault under the name
# `reservation_reminder_cron_secret` (see migration
# 20260515220500_reservation_reminder_cron.sql). Generate with:
#   openssl rand -hex 32
RESERVATION_REMINDER_CRON_SECRET=<32-byte-hex>

# Sentry crash reporting. Create a React Native project at sentry.io
# and paste the DSN below. Empty value disables Sentry (dev / test builds).
# EXPO_PUBLIC_SENTRY_ENV defaults to "production"; set to "staging" or
# "dev" for EAS preview / development channels so prod alerts stay clean.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENV=

# Google Maps / Geocoding (mobile, prebuild-time). Real values live in
# `.env` (gitignored) for local dev and in EAS Secrets for cloud builds.
# Not prefixed with EXPO_PUBLIC_ — the config plugin injects them into
# AndroidManifest.xml / Info.plist at native build time so they never
# enter the JS bundle.
GOOGLE_MAPS_API_KEY_ANDROID=
GOOGLE_MAPS_API_KEY_IOS=
GOOGLE_GEOCODING_API_KEY=
GOOGLE_MAPS_PLATFORM_API_KEY=
